{
  "defaults": {
    "dataset_name": "Hate-speech-CNERG/hatexplain",
    "selection_metric": "f1_macro",
    "test_policy": "final_only",
    "final_seeds": [42, 43, 44],
    "wandb_project": "hate-speech-ft"
  },
  "experiments": {
    "distilbert_full_smoke": {
      "status": "ready",
      "method": "full-ft",
      "family": "transformer",
      "stage": "smoke",
      "script": "src/run_distilbert_hatexplain.py",
      "description": "Fast smoke test for the current DistilBERT full fine-tuning path.",
      "tags": ["distilbert", "full-ft", "smoke"],
      "args": {
        "model_name": "distilbert-base-uncased",
        "dataset_name": "Hate-speech-CNERG/hatexplain",
        "max_length": 128,
        "learning_rate": 2e-5,
        "weight_decay": 0.01,
        "warmup_ratio": 0.0,
        "per_device_train_batch_size": 8,
        "per_device_eval_batch_size": 8,
        "num_train_epochs": 1,
        "seed": 42,
        "max_train_samples": 64,
        "max_eval_samples": 64,
        "output_dir": "outputs/distilbert_full_smoke"
      }
    },
    "distilbert_full_quick": {
      "status": "ready",
      "method": "full-ft",
      "family": "transformer",
      "stage": "quick",
      "script": "src/run_distilbert_hatexplain.py",
      "description": "Quick DistilBERT full fine-tuning sanity run.",
      "tags": ["distilbert", "full-ft", "quick"],
      "args": {
        "model_name": "distilbert-base-uncased",
        "dataset_name": "Hate-speech-CNERG/hatexplain",
        "max_length": 128,
        "learning_rate": 2e-5,
        "weight_decay": 0.01,
        "warmup_ratio": 0.0,
        "per_device_train_batch_size": 8,
        "per_device_eval_batch_size": 8,
        "num_train_epochs": 1,
        "seed": 42,
        "max_train_samples": 512,
        "max_eval_samples": 256,
        "output_dir": "outputs/distilbert_full_quick"
      }
    },
    "distilbert_full_final_seed42": {
      "status": "ready",
      "method": "full-ft",
      "family": "transformer",
      "stage": "final",
      "script": "src/run_distilbert_hatexplain.py",
      "description": "Full-data DistilBERT baseline for one final seed.",
      "tags": ["distilbert", "full-ft", "final"],
      "args": {
        "model_name": "distilbert-base-uncased",
        "dataset_name": "Hate-speech-CNERG/hatexplain",
        "max_length": 128,
        "learning_rate": 2e-5,
        "weight_decay": 0.01,
        "warmup_ratio": 0.0,
        "per_device_train_batch_size": 8,
        "per_device_eval_batch_size": 8,
        "num_train_epochs": 3,
        "seed": 42,
        "data_fraction": 1.0,
        "run_test": true,
        "output_dir": "outputs/distilbert_full_final_seed42"
      }
    },
    "tfidf_logreg_template": {
      "status": "planned",
      "method": "tfidf-logreg",
      "family": "classical",
      "stage": "template",
      "script": "src/methods/tfidf_logreg/train.py",
      "description": "Template for the TF-IDF + Logistic Regression baseline.",
      "tags": ["tfidf", "logreg", "baseline"],
      "args": {
        "dataset_name": "Hate-speech-CNERG/hatexplain",
        "ngram_range": [1, 2],
        "min_df": 2,
        "max_features": 50000,
        "C": 1.0,
        "class_weight": "balanced",
        "seed": 42,
        "output_dir": "outputs/tfidf_logreg_template"
      }
    },
    "bilstm_template": {
      "status": "planned",
      "method": "bilstm",
      "family": "neural-scratch",
      "stage": "template",
      "script": "src/methods/bilstm/train.py",
      "description": "Template for a Bi-LSTM trained from scratch.",
      "tags": ["bilstm", "scratch", "baseline"],
      "args": {
        "dataset_name": "Hate-speech-CNERG/hatexplain",
        "embedding_size": 100,
        "hidden_size": 128,
        "dropout": 0.3,
        "learning_rate": 1e-3,
        "batch_size": 32,
        "epochs": 5,
        "seed": 42,
        "output_dir": "outputs/bilstm_template"
      }
    },
    "frozen_distilbert_template": {
      "status": "planned",
      "method": "frozen-backbone",
      "family": "transformer",
      "stage": "template",
      "script": "src/methods/distilbert_frozen/train.py",
      "description": "Template for frozen DistilBERT backbone plus classifier head.",
      "tags": ["distilbert", "frozen-backbone"],
      "args": {
        "model_name": "distilbert-base-uncased",
        "max_length": 128,
        "head_learning_rate": 1e-4,
        "weight_decay": 0.01,
        "batch_size": 8,
        "epochs": 3,
        "seed": 42,
        "output_dir": "outputs/frozen_distilbert_template"
      }
    },
    "partial_distilbert_template": {
      "status": "planned",
      "method": "partial-ft",
      "family": "transformer",
      "stage": "template",
      "script": "src/methods/distilbert_partial/train.py",
      "description": "Template for partial DistilBERT fine-tuning.",
      "tags": ["distilbert", "partial-ft"],
      "args": {
        "model_name": "distilbert-base-uncased",
        "max_length": 128,
        "learning_rate": 2e-5,
        "unfrozen_layers": 2,
        "weight_decay": 0.01,
        "batch_size": 8,
        "epochs": 3,
        "seed": 42,
        "output_dir": "outputs/partial_distilbert_template"
      }
    },
    "lora_distilbert_template": {
      "status": "planned",
      "method": "lora",
      "family": "transformer-peft",
      "stage": "template",
      "script": "src/methods/distilbert_lora/train.py",
      "description": "Template for LoRA on DistilBERT.",
      "tags": ["distilbert", "lora", "peft"],
      "args": {
        "model_name": "distilbert-base-uncased",
        "max_length": 128,
        "learning_rate": 3e-4,
        "lora_r": 8,
        "lora_alpha": 16,
        "lora_dropout": 0.1,
        "target_modules": ["q_lin", "v_lin"],
        "epochs": 3,
        "seed": 42,
        "output_dir": "outputs/lora_distilbert_template"
      }
    },
    "lp_ft_template": {
      "status": "planned",
      "method": "lp-ft",
      "family": "transformer-two-stage",
      "stage": "template",
      "script": "src/methods/distilbert_lp_ft/train.py",
      "description": "Template for linear probing followed by full fine-tuning.",
      "tags": ["distilbert", "lp-ft", "two-stage"],
      "args": {
        "model_name": "distilbert-base-uncased",
        "max_length": 128,
        "stage1_head_learning_rate": 1e-4,
        "stage1_epochs": 2,
        "stage2_learning_rate": 2e-5,
        "stage2_epochs": 2,
        "weight_decay": 0.01,
        "seed": 42,
        "output_dir": "outputs/lp_ft_template"
      }
    },
    "efficient_head_ft_template": {
      "status": "planned",
      "method": "efficient-head-ft",
      "family": "transformer-two-stage",
      "stage": "template",
      "script": "src/methods/distilbert_efficient_head/train.py",
      "description": "Template for efficient head fine-tuning.",
      "tags": ["distilbert", "efficient-head-ft", "two-stage"],
      "args": {
        "model_name": "distilbert-base-uncased",
        "max_length": 128,
        "stage1_learning_rate": 3e-4,
        "stage1_epochs": 2,
        "stage2_learning_rate": 2e-5,
        "stage2_epochs": 2,
        "seed": 42,
        "output_dir": "outputs/efficient_head_ft_template"
      }
    }
  }
}
